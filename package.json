{
  "name": "elective-dashboard",
  "version": "1.0.0",
  "description": "IIM Sambalpur Electives Explorer Dashboard",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "npm run dev --prefix client",
    "install:all": "npm install && npm install --prefix client",
    "build": "cd client && npm install && npm run build",
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "seed:details": "node scripts/seed-course-details.js",
    "migrate:anonymous": "node server/migrations/add_anonymous_flag.js"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@supabase/supabase-js": "^2.103.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "pdfkit": "^0.18.0"
  }
}
